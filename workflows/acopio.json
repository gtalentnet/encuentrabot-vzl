      }
    },
    {
      "parameters": {
        "jsCode": "const text = $json?.message?.text || '';\nconst chatId = $json?.message?.chat?.id;\n\nif (!text.startsWith('/acopio')) return [];\n\nconst zona = text.replace('/acopio', '').trim() || null;\nreturn [{ json: { chatId, zona } }];"
      },
      "id": "eb-parse-acopio",
      "name": "Parsear Comando",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [460, 300]
    },
    {
      "parameters": {
