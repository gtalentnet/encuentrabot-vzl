# ============================================================
# EncuentraBot VZL — Variables de Entorno
# Copia este archivo como .env y completa los valores reales.
# NUNCA subas .env al repositorio.
# ============================================================

# --- Zona horaria (obligatoria) ---
TZ=America/Caracas

# --- n8n ---
N8N_HOST=localhost
N8N_PROTOCOL=http
N8N_USER=admin
N8N_PASSWORD=cambia_esto_en_produccion
N8N_ENCRYPTION_KEY=genera_una_clave_segura_aqui_32chars

# --- Ngrok / Webhook público ---
# Pega aquí la URL HTTPS que entrega Ngrok al ejecutar: ngrok http 5678
# Ejemplo: https://abcd-1234.ngrok-free.app
WEBHOOK_URL=https://TU_URL_NGROK.ngrok-free.app

# --- Supabase ---
# Encuéntralos en: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://xxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...tu_anon_key...
SUPABASE_SERVICE_ROLE_KEY=eyJ...tu_service_role_key...

# --- Telegram ---
# Obtenlo hablando con @BotFather en Telegram → /newbot
TELEGRAM_BOT_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
